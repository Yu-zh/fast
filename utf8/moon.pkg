import {
  "moonbitlang/core/builtin",
  "moonbitlang/core/v128",
}

import {
  "moonbitlang/core/bench",
  "moonbitlang/core/encoding/utf8" @encutf8,
  "moonbitlang/core/test",
} for "test"

warnings = "-missing_doc-alert_experimental"

options(
  targets: { "alloc_js.mbt": [ "js" ], "alloc_nonjs.mbt": [ "not", "js" ] },
)
